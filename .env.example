# LLM provider abstraction
# Supported values: openai, azure_openai
LLM_PROVIDER=openai

# OpenAI public API settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI settings (used when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Model runtime settings
MODEL_TEMPERATURE=0.0
MODEL_MAX_RETRIES=3
REQUEST_TIMEOUT=60

# Agent URLs
INVENTORY_AGENT_URL=http://localhost:8001/invoke
SUPPLIER_AGENT_URL=http://localhost:8002/invoke
SUPERVISOR_URL=http://localhost:8000/copilot

# Optional Azure AI Search settings
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=

# Application settings
DEBUG=true

# Azure AI Foundry settings
AZURE_AI_PROJECT_ENDPOINT=
FOUNDRY_AGENT_MODEL=gpt-4.1
FOUNDRY_AGENT_ID=
# Default: use the Foundry agent that calls the Supervisor multi-agent endpoint.
FOUNDRY_AGENT_KEY=supervisor_agent
# Optional key-specific IDs. Useful when you create multiple Foundry agents.
FOUNDRY_SUPERVISOR_AGENT_ID=
FOUNDRY_INVENTORY_AGENT_ID=
FOUNDRY_SUPPLIER_AGENT_ID=
FOUNDRY_AGENT_DEPLOYMENT_FILE=deployment/foundry_agents.json

# Streamlit observability settings
STREAMLIT_OBSERVABILITY_LOG=logs/streamlit_foundry_events.jsonl
