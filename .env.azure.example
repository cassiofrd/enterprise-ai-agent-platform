# Azure-first runtime configuration for Azure Container Apps or local Azure OpenAI testing
LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_without_quotes
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-12-01-preview

MODEL_TEMPERATURE=0.0
MODEL_MAX_RETRIES=3
REQUEST_TIMEOUT=60

INVENTORY_AGENT_URL=http://localhost:8001/invoke
SUPPLIER_AGENT_URL=http://localhost:8002/invoke
SUPERVISOR_URL=http://localhost:8000/copilot

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=supply-chain-docs
